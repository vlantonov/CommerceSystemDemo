{
  "id": null,
  "uid": "commerce-observability-p2",
  "title": "Commerce Observability - P2 Domain",
  "tags": ["commerce", "otel", "priority-2"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Search Request Rate (req/s)",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(commerce_search_requests_total[5m]))",
          "legendFormat": "search req/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Search Zero-result Rate (req/s)",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(commerce_search_zero_results_total[5m]))",
          "legendFormat": "zero-result req/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Search Zero-result Ratio (%)",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(commerce_search_zero_results_total[5m])) / clamp_min(sum(rate(commerce_search_requests_total[5m])), 0.00001))",
          "legendFormat": "zero ratio %"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "P95 Search Result Count",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(commerce_search_result_count_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Product Mutations by Result (req/s)",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(commerce_product_mutations_total[5m])) by (operation, result)",
          "legendFormat": "{{operation}} {{result}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Category Mutations by Result (req/s)",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(commerce_category_mutations_total[5m])) by (operation, result)",
          "legendFormat": "{{operation}} {{result}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Category Validation Failures (req/s)",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(commerce_category_validation_failures_total[5m])) by (reason)",
          "legendFormat": "{{reason}}"
        }
      ]
    }
  ]
}
