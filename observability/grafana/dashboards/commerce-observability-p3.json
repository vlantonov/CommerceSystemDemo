{
  "id": null,
  "uid": "commerce-observability-p3",
  "title": "Commerce Observability - P3 Diagnostics",
  "tags": ["commerce", "otel", "priority-3"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "P95 Response Time (ms)",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(commerce_http_response_time_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "P95 Processing Time (ms)",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(commerce_http_processing_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "P95 Queue Wait Time (ms)",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(commerce_http_queue_wait_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "P95 Response Payload Size (bytes)",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(commerce_http_response_payload_size_bytes_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "DB Query Duration by Operation (ms)",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(commerce_db_query_duration_seconds_bucket[5m])) by (le, db_operation)) * 1000",
          "legendFormat": "{{db_operation}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Errors by Type (req/s)",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(commerce_http_errors_total[5m])) by (error_type)",
          "legendFormat": "{{error_type}}"
        }
      ]
    }
  ]
}
