server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: __REMOTE_LOKI_PUSH_URL__

scrape_configs:
  - job_name: docker-logs
    static_configs:
      - targets:
          - localhost
        labels:
          job: __REMOTE_LOG_JOB__
          host: __REMOTE_LOG_HOST__
          __path__: /var/lib/docker/containers/*/*-json.log
    pipeline_stages:
      - docker: {}